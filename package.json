{
  "name": "thanh-hoa-land",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file=.env.local prisma/seed.ts",
    "db:clear-test-data": "tsx --env-file=.env.local prisma/clear-test-data.ts",
    "db:clear-test-data:apply": "DRY_RUN=false tsx --env-file=.env.local prisma/clear-test-data.ts",
    "check": "npm run lint && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "postcss": "^8.5.16",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-leaflet": "^5.0.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.2.3",
    "prisma": "^6.19.3",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0"
  }
}
