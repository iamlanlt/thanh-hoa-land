generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Property {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  shortDescription String?
  description      String?
  location         String
  address          String?
  lat              Float?
  lng              Float?
  area             Float?
  price            String?
  priceValue       Float?
  priceUnit        String?
  type             String?
  legalStatus      String?
  frontage         Float?
  accessRoadWidth  Float?
  direction        String?
  floors           Int?
  bedrooms         Int?
  bathrooms        Int?
  furniture        String?
  status           String          @default("AVAILABLE")
  featured         Boolean         @default(false)
  published        Boolean         @default(true)
  sortOrder        Int             @default(0)
  coverImage       String?
  videoUrls        String[]        @default([])
  deletedAt        DateTime?
  publishedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  images           PropertyImage[]
  leads            Lead[]

  @@index([published, featured, sortOrder])
  @@index([published, publishedAt])
  @@index([location])
  @@index([type])
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  publicId   String?
  alt        String?
  sortOrder  Int      @default(0)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([propertyId, sortOrder])
}

model Lead {
  id         String    @id @default(cuid())
  name       String
  phone      String
  location   String?
  budget     String?
  message    String?
  consent    Boolean   @default(false)
  status     String    @default("NEW")
  note       String?
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([propertyId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
